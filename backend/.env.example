# Server Configuration
PORT=5000
NODE_ENV=production

# MongoDB Connection (MongoDB Atlas)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/taskflow?appName=TaskFlow

# JWT Secret Keys (Generate strong random strings for production!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production

# Client/Frontend URL (IMPORTANT: Change to your production domain!)
CLIENT_URL=https://yourdomain.com

# Email Configuration - Brevo API (Recommended for Production)
BREVO_API_KEY=your-brevo-api-key-here
EMAIL_USER=your-verified-sender@example.com

# Email Configuration - SMTP Fallback (Optional)
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_PASSWORD=your-smtp-password-if-using-smtp

# Instructions:
# 1. Copy this file to .env
# 2. Replace all placeholder values with your actual credentials
# 3. NEVER commit the .env file to Git!
# 4. For cPanel deployment, set these as environment variables in Node.js App interface
